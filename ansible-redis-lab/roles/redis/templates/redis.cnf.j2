bind {{redis_bind}}
port {{redis_port}}

supervised systemd
daemonize no

dir /var/lib/redis
logfile /var/log/redis/redis-server.log

{% if redis_password %}
requirepass {{redis_password}}
{% endif %}

maxmemory {{redis_maxmemory}}
maxmemory-policy {{redis_maxmemory_policy}}

appendonly {{redis_appendonly}}

protected-mode yes
